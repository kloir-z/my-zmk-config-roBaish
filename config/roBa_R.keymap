#include "roBa_L.keymap"
#include <input/processors.dtsi>

#include "boards/shields/Test/roBa_R.overlay"
&trackball {
    // automouse-layer はドライバ側で管理せず、zip_temp_layer 側に一本化する。
    // （ドライバの k_timer が切れると延長中でも MOUSE レイヤーを消してしまい、
    //   クリック/スクロールでのタイムアウト延長と併存できないため）
    // automouse-layer = <MOUSE>;
    scroll-layers = <SCROLL>;
    snipe-layers = <2>;

    // arrows {
    //     layers = <2>;
    //     bindings =
    //         <&kp RIGHT_ARROW>,
    //         <&kp LEFT_ARROW>,
    //         <&kp UP_ARROW>,
    //         <&kp DOWN_ARROW>;

    //     tick = <5>;
    //     wait-ms = <5>;
    //     tap-ms = <5>;
    // };

};

// オートマウスレイヤー(MOUSE)の誤爆対策。
// require-prior-idle-ms: 直前 150ms 以内にキー入力があれば、トラボ移動でも MOUSE を発動させない（タイピング中の誤爆防止の本命）。
// excluded-positions: AML 中でも下記の位置のキーは MOUSE を抜けない（クリック/スクロール継続用）。
//   それ以外のキーを押すと押した瞬間に MOUSE を抜ける（通常の &kp/&mt のまま通るのでホールド/長押しリピートは壊れない）。
//   7=I(MB1) 8=O(scroll) 9=P(MB2) 19=K(MB1) 42=右親指(MB1)
//   ※ I/O/P を打って誤爆するのが気になる場合は 7 と 9 をリストから外すと、それらも押下で即解除になる。
&zip_temp_layer {
    require-prior-idle-ms = <150>;
    excluded-positions = <7 8 9 19 42>;
};

// クリック・右クリック・スクロールでも MOUSE レイヤーのタイムアウトを延長する。
// 物理トラックボールの移動・スクロールは trackball_listener (roBa_R.overlay) 側で延長。
&mkp_input_listener {
    input-processors = <&zip_temp_layer MOUSE 2000>;
};

&msc_input_listener {
    input-processors = <&zip_temp_layer MOUSE 2000>;
};
